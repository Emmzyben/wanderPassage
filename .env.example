# WanderPassage Frontend Environment Variables
# Copy this file to .env and fill in your values

# The base URL of your PHP backend (no trailing slash)
# Development (XAMPP/WAMP):
VITE_API_BASE_URL=http://localhost/wanderPassage/backend/auth

# Production example:
# VITE_API_BASE_URL=https://yourdomain.com/backend/auth
